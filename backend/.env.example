PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cbpa_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Stellar Network (use 'testnet' for development, 'mainnet' for production)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Encryption key for private keys (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here_

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# SMTP (email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@afripay.com

# KYC transaction threshold in USD equivalent (default: 100)
KYC_THRESHOLD_USD=100

# Approximate XLM/USD rate for threshold checks (replace with live feed in production)
XLM_USD_RATE=0.11
# USDC issuer address on Stellar
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Soroban RPC endpoint (required for contract event indexer)
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Comma-separated list of deployed Soroban contract IDs to index
# e.g. SOROBAN_CONTRACT_IDS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
SOROBAN_CONTRACT_IDS=

# Cron schedules (standard cron syntax, defaults shown)
CRON_SCHEDULED_PAYMENTS=* * * * *      # every minute
CRON_CONTRACT_INDEXER=*/2 * * * *      # every 2 minutes
CRON_CLAIMABLE_EXPIRY=*/15 * * * *     # every 15 minutes

# Hours before expiry to send claimable balance warning notifications (default: 24)
CLAIMABLE_BALANCE_WARN_HOURS=24
